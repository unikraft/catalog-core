#!/bin/sh

if test ! -f "workdir/build/flask3.0-python3.10_xen-arm64"; then
    echo "No kernel file workdir/build/flask3.0-python3.10_xen-arm64." 1>&2
    echo "Did you run ./scripts/build/xen.arm64 ?" 1>&2
    exit 1
fi

rm -fr ./rootfs
docker build -o ./rootfs -f Dockerfile .

rm -f initrd.cpio
../repos/unikraft/support/scripts/mkcpio initrd.cpio ./rootfs/

sudo xl create -c xen.arm64.cfg
