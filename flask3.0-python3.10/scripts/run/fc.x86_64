#!/bin/sh

if test ! -f "workdir/build/flask3.0-python3.10_fc-x86_64"; then
    echo "No kernel file workdir/build/flask3.0-python3.10_fc-x86_64." 1>&2
    echo "Did you run ./scripts/build/fc.x86_64 ?" 1>&2
    exit 1
fi

rm -fr ./rootfs
docker build -o ./rootfs -f Dockerfile .

rm -f initrd.cpio
../repos/unikraft/support/scripts/mkcpio initrd.cpio ./rootfs/

rm -f firecracker.socket

firecracker-x86_64 \
        --api-sock firecracker.socket \
        --config-file fc.x86_64.json
